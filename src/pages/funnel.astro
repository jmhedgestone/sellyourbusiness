---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';

const title = 'Business Valuation | John Matsis – HedgeStone Business Advisors';
const description =
  'Get your free, confidential business valuation in under 3 minutes. Current market multiples applied to your financials by John Matsis at HedgeStone Business Advisors.';
---

<BaseLayout title={title} description={description} bodyClass="funnel-body" noindex={false}>
  <Fragment slot="head">
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>
  </Fragment>

  <Nav variant="funnel" />

  <div class="funnel-wrap">
    <div class="funnel-header" id="funnelHeader">
      <div class="section-label" id="funnelEyebrow">Step-by-Step</div>
      <h1 id="funnelHeadline">What Is Your Business Worth?</h1>
      <p id="funnelSubhead">Answer a few quick questions and get your personalized valuation report — no obligation, 100% confidential.</p>
    </div>

    <!-- PROGRESS BAR -->
    <div class="progress-wrap">
      <div class="progress-steps" id="progressSteps">
        <div class="progress-line" id="progressLine"></div>
        <div class="step-dot active" data-step="1">1</div>
        <div class="step-dot" data-step="2">2</div>
        <div class="step-dot" data-step="3">
          <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        </div>
        <div class="step-dot" data-step="4">4</div>
      </div>
      <div class="progress-labels">
        <span>Your Business</span>
        <span>Financials</span>
        <span>Your Situation</span>
        <span>Contact Info</span>
      </div>
    </div>

    <!-- FORM CARD -->
    <form class="form-card" id="valuationForm" novalidate>

      <!-- STEP 1: Business Info -->
      <div class="step active" data-step="1">
        <h2 class="step-title">Tell us about your business</h2>
        <p class="step-subtitle">Just the basics — no financials yet.</p>

        <div class="field">
          <label for="businessName">Business Name</label>
          <input type="text" id="businessName" name="businessName" placeholder="e.g. Acme Holdings LLC" autocomplete="organization" />
          <div class="error-msg" id="err-businessName">Please enter your business name.</div>
        </div>

        <div class="field">
          <label for="industry">Industry</label>
          <select id="industry" name="industry">
            <option value="">Select your industry…</option>
            <option>Technology / Software</option>
            <option>Professional Services</option>
            <option>Healthcare / Medical</option>
            <option>Retail</option>
            <option>Restaurant / Food &amp; Beverage</option>
            <option>Manufacturing</option>
            <option>E-commerce</option>
            <option>Construction / Trades</option>
            <option>Transportation / Logistics</option>
            <option>Real Estate Services</option>
            <option>Wholesale / Distribution</option>
            <option>Financial Services</option>
            <option>Marketing / Advertising</option>
            <option>Other</option>
          </select>
          <div class="error-msg" id="err-industry">Please select your industry.</div>
        </div>

        <div class="field">
          <label for="websiteUrl">Business Website <span class="opt">(optional)</span></label>
          <input type="url" id="websiteUrl" name="websiteUrl" placeholder="https://yourbusiness.com" />
        </div>

        <div class="field">
          <label for="yearsInBusiness">Years in Business</label>
          <select id="yearsInBusiness" name="yearsInBusiness">
            <option value="">Select…</option>
            <option value="under1">Less than 1 year</option>
            <option value="1to3">1 – 3 years</option>
            <option value="3to5">3 – 5 years</option>
            <option value="5to10">5 – 10 years</option>
            <option value="over10">10+ years</option>
          </select>
          <div class="error-msg" id="err-yearsInBusiness">Please select years in business.</div>
        </div>

        <div class="form-nav">
          <button type="button" class="btn-next" onclick="nextStep(1)">
            Continue
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </button>
        </div>
      </div>

      <!-- STEP 2: Financials -->
      <div class="step" data-step="2">
        <h2 class="step-title">Paint the financial picture</h2>
        <p class="step-subtitle">Use your most recent full year. Estimates are fine.</p>

        <div class="field">
          <label for="grossRevenue">Annual Gross Revenue</label>
          <div class="money-wrap">
            <span class="prefix">$</span>
            <input type="text" id="grossRevenue" name="grossRevenue" placeholder="0" inputmode="numeric" />
          </div>
          <div class="error-msg" id="err-grossRevenue">Please enter your annual gross revenue.</div>
        </div>

        <div class="field">
          <label for="netIncome">Annual Net Income <span class="opt">/ Owner's Earnings</span></label>
          <div class="money-wrap">
            <span class="prefix">$</span>
            <input type="text" id="netIncome" name="netIncome" placeholder="0" inputmode="numeric" />
          </div>
          <div class="error-msg" id="err-netIncome">Please enter your annual net income.</div>
        </div>

        <div style="background:rgba(212,168,67,0.06);border:1px solid rgba(212,168,67,0.15);border-radius:8px;padding:14px 16px;font-size:0.82rem;color:var(--muted);line-height:1.6;margin-bottom:4px;">
          <strong style="color:var(--gold);">Tip:</strong> Net income (or SDE — Seller's Discretionary Earnings) is your profit after expenses, before owner's compensation and personal perks. This is the primary driver of your valuation.
        </div>

        <div class="form-nav">
          <button type="button" class="btn-back" onclick="prevStep(2)">Back</button>
          <button type="button" class="btn-next" onclick="nextStep(2)">
            Continue
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </button>
        </div>
      </div>

      <!-- STEP 3: Situation -->
      <div class="step" data-step="3">
        <h2 class="step-title">What brings you to this point?</h2>
        <p class="step-subtitle">This helps us tailor our approach to your specific goals.</p>

        <div class="field">
          <label>Reason for Selling</label>
          <div class="radio-grid cols-2">
            <div class="radio-card">
              <input type="radio" name="reasonForSelling" id="r-retire" value="Retirement" />
              <label for="r-retire"><span class="icon">🏖️</span>Retirement</label>
            </div>
            <div class="radio-card">
              <input type="radio" name="reasonForSelling" id="r-new" value="New Venture" />
              <label for="r-new"><span class="icon">🚀</span>New Venture</label>
            </div>
            <div class="radio-card">
              <input type="radio" name="reasonForSelling" id="r-partner" value="Partnership Change" />
              <label for="r-partner"><span class="icon">🤝</span>Partnership Change</label>
            </div>
            <div class="radio-card">
              <input type="radio" name="reasonForSelling" id="r-relocate" value="Relocation" />
              <label for="r-relocate"><span class="icon">📍</span>Relocation</label>
            </div>
            <div class="radio-card">
              <input type="radio" name="reasonForSelling" id="r-health" value="Health / Personal" />
              <label for="r-health"><span class="icon">❤️</span>Health / Personal</label>
            </div>
            <div class="radio-card">
              <input type="radio" name="reasonForSelling" id="r-other" value="Other" />
              <label for="r-other"><span class="icon">💡</span>Other</label>
            </div>
          </div>
          <div class="error-msg" id="err-reasonForSelling">Please select a reason.</div>
        </div>

        <div class="field" style="margin-top:28px;">
          <label>Preferred Contact Method</label>
          <div class="radio-grid cols-3">
            <div class="radio-card">
              <input type="radio" name="contactMethod" id="c-email" value="Email" />
              <label for="c-email"><span class="icon">📧</span>Email</label>
            </div>
            <div class="radio-card">
              <input type="radio" name="contactMethod" id="c-call" value="Phone Call" />
              <label for="c-call"><span class="icon">📞</span>Phone Call</label>
            </div>
            <div class="radio-card">
              <input type="radio" name="contactMethod" id="c-text" value="Text / SMS" />
              <label for="c-text"><span class="icon">💬</span>Text / SMS</label>
            </div>
          </div>
          <div class="error-msg" id="err-contactMethod">Please select a contact method.</div>
        </div>

        <div class="form-nav">
          <button type="button" class="btn-back" onclick="prevStep(3)">Back</button>
          <button type="button" class="btn-next" onclick="nextStep(3)">
            Continue
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </button>
        </div>
      </div>

      <!-- STEP 4: Contact Info -->
      <div class="step" data-step="4">
        <h2 class="step-title">Where should we send your report?</h2>
        <p class="step-subtitle">Your information is kept strictly confidential and never shared.</p>

        <div class="field">
          <label for="ownerName">Your Full Name</label>
          <input type="text" id="ownerName" name="ownerName" placeholder="First and Last Name" autocomplete="name" />
          <div class="error-msg" id="err-ownerName">Please enter your name.</div>
        </div>

        <div class="field-row">
          <div class="field">
            <label for="ownerEmail">Email Address</label>
            <input type="email" id="ownerEmail" name="ownerEmail" placeholder="you@company.com" autocomplete="email" />
            <div class="error-msg" id="err-ownerEmail">Please enter a valid email.</div>
          </div>
          <div class="field">
            <label for="ownerPhone">Phone Number</label>
            <input type="tel" id="ownerPhone" name="ownerPhone" placeholder="(555) 000-0000" autocomplete="tel" />
            <div class="error-msg" id="err-ownerPhone">Please enter your phone number.</div>
          </div>
        </div>

        <div style="background:rgba(212,168,67,0.06);border:1px solid rgba(212,168,67,0.15);border-radius:8px;padding:14px 16px;font-size:0.82rem;color:var(--muted);line-height:1.6;">
          <strong style="color:var(--gold);">🔒 100% Confidential:</strong> Your information is never shared with third parties. By submitting, you agree to our <a href="/privacy" target="_blank">Privacy Policy</a> and <a href="/terms" target="_blank">Terms &amp; Conditions</a>.
        </div>

        <div class="cf-turnstile" data-sitekey="0x4AAAAAADBTjHwWt_PaZpue" data-theme="dark" style="margin-top:20px;"></div>
        <div class="error-msg" id="err-captcha" style="margin-top:6px;">Please complete the security check.</div>

        <div class="form-nav">
          <button type="button" class="btn-back" onclick="prevStep(4)">Back</button>
          <button type="button" class="btn-next" id="submitBtn" onclick="submitForm()">
            Generate My Valuation
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </button>
        </div>
      </div>

    </form>

    <!-- TRUST FOOTER -->
    <div class="trust-footer">
      <div class="trust-tag">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        Secure &amp; Encrypted
      </div>
      <div class="trust-tag">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        100% Confidential
      </div>
      <div class="trust-tag">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        No Cost, No Obligation
      </div>
    </div>
    <p class="disclaimer">This valuation is an estimate based on current market multiples and the information you provide. It is not a formal appraisal or offer to purchase.</p>
  </div>

  <script is:inline>
    let currentStep = 1;
    const totalSteps = 4;

    function updateProgress(step) {
      const dots = document.querySelectorAll('.step-dot');
      const line = document.getElementById('progressLine');
      dots.forEach((dot, i) => {
        dot.classList.remove('active', 'done');
        if (i + 1 < step) {
          dot.classList.add('done');
          dot.innerHTML = '<svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>';
        } else if (i + 1 === step) {
          dot.classList.add('active');
          dot.textContent = i + 1;
        } else {
          dot.textContent = i + 1;
        }
      });
      const pct = ((step - 1) / (totalSteps - 1)) * 100;
      line.style.width = pct + '%';
    }

    function showStep(step) {
      document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
      document.querySelector('.step[data-step="' + step + '"]').classList.add('active');
      updateProgress(step);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function validateStep(step) {
      let valid = true;

      function err(id, show) {
        const el = document.getElementById('err-' + id);
        if (el) { show ? el.classList.add('show') : el.classList.remove('show'); }
        const input = document.getElementById(id) || document.querySelector('[name="' + id + '"]');
        if (input) { show ? input.classList.add('error') : input.classList.remove('error'); }
      }

      if (step === 1) {
        const biz = document.getElementById('businessName').value.trim();
        const ind = document.getElementById('industry').value;
        const yrs = document.getElementById('yearsInBusiness').value;
        err('businessName', !biz); if (!biz) valid = false;
        err('industry', !ind); if (!ind) valid = false;
        err('yearsInBusiness', !yrs); if (!yrs) valid = false;
      }

      if (step === 2) {
        const gross = parseMoney(document.getElementById('grossRevenue').value);
        const net = parseMoney(document.getElementById('netIncome').value);
        err('grossRevenue', !gross); if (!gross) valid = false;
        err('netIncome', net === null || net === undefined || net === ''); if (net === null || net === undefined || net === '') valid = false;
      }

      if (step === 3) {
        const reason = document.querySelector('input[name="reasonForSelling"]:checked');
        const contact = document.querySelector('input[name="contactMethod"]:checked');
        err('reasonForSelling', !reason); if (!reason) valid = false;
        err('contactMethod', !contact); if (!contact) valid = false;
      }

      if (step === 4) {
        const name = document.getElementById('ownerName').value.trim();
        const email = document.getElementById('ownerEmail').value.trim();
        const phone = document.getElementById('ownerPhone').value.trim();
        err('ownerName', !name); if (!name) valid = false;
        const emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
        err('ownerEmail', !emailOk); if (!emailOk) valid = false;
        err('ownerPhone', !phone); if (!phone) valid = false;

        const captcha = document.querySelector('[name="cf-turnstile-response"]') ? document.querySelector('[name="cf-turnstile-response"]').value : null;
        const captchaErr = document.getElementById('err-captcha');
        if (!captcha) {
          captchaErr.classList.add('show');
          valid = false;
        } else {
          captchaErr.classList.remove('show');
        }
      }

      return valid;
    }

    function nextStep(step) {
      if (!validateStep(step)) return;
      currentStep = step + 1;
      showStep(currentStep);
    }

    function prevStep(step) {
      currentStep = step - 1;
      showStep(currentStep);
    }

    function parseMoney(val) {
      return parseFloat(val.replace(/[^0-9.]/g, '')) || 0;
    }

    const SUBMIT_ENDPOINT = '/api/submit';

    // ─── UTM-aware copy swap ────────────────────────────────────────────────
    // Reads first-touch UTMs from localStorage (captured on landing) and the
    // current URL, then swaps the headline / subhead / eyebrow to match the
    // campaign that brought them here. Falls back to the static defaults
    // baked into the HTML when no UTMs are present.
    //
    // To add a new variant: append to the COPY_VARIANTS map. Match keys can
    // be utm_source ('instagram'), utm_medium ('paid-social'), or
    // utm_campaign ('retargeting-q2'). First match wins, in order.
    (function applyUtmAwareCopy() {
      const COPY_VARIANTS = [
        // Instagram traffic — short, conversational, brand-led.
        { match: { utm_source: 'instagram' }, eyebrow: 'From Instagram',
          headline: 'Your Business — What\'s It Actually Worth?',
          subhead: 'You saw the post. Now get the number. 3 minutes, free, confidential.' },
        // Facebook prospecting — broader, value-focused.
        { match: { utm_source: 'facebook' }, eyebrow: 'Free Valuation',
          headline: 'Find Out What Your Business Could Sell For',
          subhead: 'Real multiples, applied to your numbers, by a working broker. 3 minutes, no obligation.' },
        // Google search — high-intent, direct.
        { match: { utm_source: 'google' }, eyebrow: 'Confidential Estimate',
          headline: 'Get Your Business Valuation — Free',
          subhead: 'Industry-specific multiples applied to your financials. Takes 3 minutes. 100% confidential.' },
        // Retargeting — addressing hesitation.
        { match: { utm_campaign: 'retargeting' }, eyebrow: 'Picking Up Where You Left Off',
          headline: 'Still Curious What Your Business Is Worth?',
          subhead: 'Same 3-minute form, same confidential estimate. No spam, no sales pressure.' },
        // YouTube / Reels content — trust-led.
        { match: { utm_source: 'youtube' }, eyebrow: 'From the Video',
          headline: 'Get Your Specific Number',
          subhead: 'Apply the same method John walked through to your actual financials. 3 minutes.' },
        { match: { utm_medium: 'reels' }, eyebrow: 'From the Reel',
          headline: 'Get Your Specific Number',
          subhead: 'Apply the same method to your actual financials. 3 minutes, free, confidential.' },
      ];

      function getUtmContext() {
        const ctx = {};
        try {
          const last = JSON.parse(localStorage.getItem('syb_utm_last') || '{}');
          const first = JSON.parse(localStorage.getItem('syb_utm_first') || '{}');
          ['utm_source','utm_medium','utm_campaign'].forEach((k) => {
            ctx[k] = (last[k] || first[k] || '').toLowerCase();
          });
        } catch (_) {}
        // Current URL wins over storage if present
        try {
          const params = new URLSearchParams(window.location.search);
          ['utm_source','utm_medium','utm_campaign'].forEach((k) => {
            const v = params.get(k);
            if (v) ctx[k] = v.toLowerCase();
          });
        } catch (_) {}
        return ctx;
      }

      const ctx = getUtmContext();
      if (!ctx.utm_source && !ctx.utm_medium && !ctx.utm_campaign) return;

      const variant = COPY_VARIANTS.find((v) =>
        Object.entries(v.match).every(([k, val]) =>
          (ctx[k] || '').indexOf(String(val).toLowerCase()) !== -1
        )
      );
      if (!variant) return;

      const eyebrow = document.getElementById('funnelEyebrow');
      const headline = document.getElementById('funnelHeadline');
      const subhead = document.getElementById('funnelSubhead');
      if (eyebrow && variant.eyebrow) eyebrow.textContent = variant.eyebrow;
      if (headline && variant.headline) headline.textContent = variant.headline;
      if (subhead && variant.subhead) subhead.textContent = variant.subhead;
    })();
    // ────────────────────────────────────────────────────────────────────────

    // Meta Pixel: ViewContent fires once when the user reaches the funnel.
    // Useful for retargeting and lookalike audiences.
    if (typeof fbq === 'function') {
      fbq('track', 'ViewContent', {
        content_name: 'Business Valuation Funnel',
        content_category: 'lead-generation',
      });
    }

    function newEventId() {
      // Used to dedupe browser pixel + server CAPI events for the same Lead.
      if (window.crypto && typeof window.crypto.randomUUID === 'function') {
        return window.crypto.randomUUID();
      }
      return 'lead-' + Date.now() + '-' + Math.random().toString(36).slice(2, 10);
    }

    function readUtms() {
      // Merge first-touch + last-touch UTM/click-id state captured by
      // the MetaPixel component on landing. First-touch wins for source
      // attribution; last-touch fills any gaps.
      var out = {};
      try {
        var last = JSON.parse(localStorage.getItem('syb_utm_last') || '{}');
        var first = JSON.parse(localStorage.getItem('syb_utm_first') || '{}');
        ['utm_source','utm_medium','utm_campaign','utm_term','utm_content','fbclid','gclid'].forEach(function(k){
          if (first[k]) out[k] = first[k];
          else if (last[k]) out[k] = last[k];
        });
      } catch (_) { /* non-fatal */ }
      return out;
    }

    async function submitForm() {
      if (!validateStep(4)) return;

      const eventId = newEventId();
      const utms = readUtms();

      const data = {
        businessName:    document.getElementById('businessName').value.trim(),
        industry:        document.getElementById('industry').value,
        websiteUrl:      document.getElementById('websiteUrl').value.trim(),
        yearsInBusiness: document.getElementById('yearsInBusiness').value,
        grossRevenue:    parseMoney(document.getElementById('grossRevenue').value),
        netIncome:       parseMoney(document.getElementById('netIncome').value),
        reasonForSelling: (document.querySelector('input[name="reasonForSelling"]:checked') || {}).value,
        contactMethod:   (document.querySelector('input[name="contactMethod"]:checked') || {}).value,
        ownerName:       document.getElementById('ownerName').value.trim(),
        ownerEmail:      document.getElementById('ownerEmail').value.trim(),
        ownerPhone:      document.getElementById('ownerPhone').value.trim(),
        submittedAt:     new Date().toISOString(),
        eventId:         eventId,
        utms:            utms,
      };

      localStorage.setItem('valuationData', JSON.stringify(data));

      const btn = document.getElementById('submitBtn');
      btn.disabled = true;
      btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="animation:spin 1s linear infinite"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg> Generating…';

      try {
        const turnstileEl = document.querySelector('[name="cf-turnstile-response"]');
        const res = await fetch(SUBMIT_ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({
            ...data,
            'cf-turnstile-response': turnstileEl ? turnstileEl.value : null,
          })
        });
        const json = await res.json();
        console.log('Submit response:', res.status, json);
        if (!res.ok) {
          console.error('Submit error:', json);
        }
      } catch (err) {
        console.error('Submit fetch failed:', err);
      }

      // Meta Pixel: Lead event. Sent with the same eventID as the server-side
      // CAPI event for deduplication. UTMs flow into custom_data so we can
      // attribute leads to specific ad sets in Events Manager.
      if (typeof fbq === 'function') {
        // Lead value of 100 gives Meta's algorithm a non-zero signal to
        // optimize toward valuable users. Real EV is much higher, but the
        // optimizer cares about relative ranking, not absolute dollars.
        fbq('track', 'Lead', Object.assign({
          content_name: 'Business Valuation Request',
          content_category: data.industry || 'unspecified',
          value: 100,
          currency: 'USD',
        }, utms), { eventID: eventId });
      }

      window.location.href = '/report';
    }

    ['grossRevenue', 'netIncome'].forEach(id => {
      const el = document.getElementById(id);
      el.addEventListener('input', () => {
        const raw = el.value.replace(/[^0-9]/g, '');
        if (raw) el.value = parseInt(raw, 10).toLocaleString();
        else el.value = '';
      });
    });
  </script>
</BaseLayout>

