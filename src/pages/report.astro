---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';

const title = 'Your Business Valuation Report | John Matsis – HedgeStone';
const description =
  'Your confidential business valuation report — generated by John Matsis with HedgeStone Business Advisors.';
---

<BaseLayout title={title} description={description} noindex={true}>
  <Nav variant="report" />

  <div class="report-wrap">

    <div class="report-card" id="reportCard">

      <!-- HEADER -->
      <div class="report-header">
        <div class="report-header-left">
          <img class="report-hedgstone-logo"
            src="https://www.hedgestone.com/wp-content/uploads/2022/07/HedgeStone-logo-sh.svg"
            alt="HedgeStone Business Advisors" />
          <div class="report-title">Confidential Business Valuation Estimate</div>
          <h1 class="report-business-name" id="rBusinessName">—</h1>
          <div class="report-industry" id="rIndustry"></div>
        </div>
        <img class="report-biz-logo" id="rBizLogo" src="" alt="Business Logo" />
        <div class="report-biz-initials" id="rBizInitials"></div>
      </div>

      <!-- VALUATION HERO -->
      <div class="valuation-hero">
        <div class="valuation-label">Estimated Valuation Range</div>
        <div class="valuation-range" id="rValuationRange">—</div>
        <div class="valuation-note" id="rValuationNote"></div>
        <div class="confidence-bar-wrap">
          <div class="confidence-label">
            <span>Conservative</span>
            <span>Optimistic</span>
          </div>
          <div class="confidence-bar">
            <div class="confidence-fill" id="rConfidenceFill" style="width:0%"></div>
          </div>
        </div>
      </div>

      <!-- BREAKDOWN -->
      <div class="breakdown-section">
        <div class="breakdown-title">Financial Snapshot</div>
        <div class="breakdown-grid">
          <div class="breakdown-item">
            <div class="b-label">Gross Revenue</div>
            <div class="b-value" id="rGross">—</div>
            <div class="b-sub">Annual</div>
          </div>
          <div class="breakdown-item">
            <div class="b-label">Net Income / SDE</div>
            <div class="b-value" id="rNet">—</div>
            <div class="b-sub">Owner's Earnings</div>
          </div>
          <div class="breakdown-item">
            <div class="b-label">Years in Business</div>
            <div class="b-value" id="rYears">—</div>
            <div class="b-sub">Operational history</div>
          </div>
        </div>
      </div>

      <!-- METHODOLOGY -->
      <div class="method-section">
        <div class="method-title">How Your Valuation Was Calculated</div>
        <div class="method-text">
          This estimate applies current market valuation multiples based on your sector, years in operation, and financials.
          Small and mid-size businesses are typically valued using a multiple of Seller's Discretionary Earnings (SDE) —
          the profit available to a working owner — adjusted for time in business and industry risk.
        </div>
        <table class="method-table" id="rMethodTable">
          <thead>
            <tr>
              <th>Method</th>
              <th>Base Figure</th>
              <th>Multiple</th>
              <th>Result</th>
            </tr>
          </thead>
          <tbody id="rMethodBody"></tbody>
        </table>
      </div>

      <!-- BROKER SECTION -->
      <div class="broker-section">
        <img class="broker-photo" src="/assets/john-matsis.jpg" alt="John Matsis" />
        <div class="broker-info">
          <div class="greeting">A Personal Note From Your Broker</div>
          <h3>John Matsis</h3>
          <div class="broker-title">Business &amp; Investment Property Broker and Principal &bull; HedgeStone Business Advisors</div>
          <p id="rPersonalNote">Thank you for taking the first step. This estimate gives you a realistic starting point — but the true value of your business is often uncovered through a deeper conversation about your story, your goals, and the unique strengths you've built over the years. I'll be reaching out shortly via your preferred contact method to discuss next steps. In the meantime, feel free to reach out directly — I'm here to help.</p>
          <div class="broker-contact-row">
            <a href="tel:2126780100">
              <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              (212) 678-0100
            </a>
            <a href="mailto:john.matsis@hedgestone.com">
              <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              john.matsis@hedgestone.com
            </a>
          </div>
        </div>
      </div>

      <!-- REPORT FOOTER -->
      <div class="report-footer">
        <p>Generated <span id="rDate"></span> &bull; Confidential &bull; HedgeStone Business Advisors</p>
        <div class="actions">
          <button class="btn-print" onclick="window.print()">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
            Save / Print
          </button>
          <a href="/" class="btn-print">Back to Home</a>
        </div>
      </div>

    </div>

    <!-- DISCLAIMER -->
    <div class="disclaimer-box">
      <p><strong style="color:var(--text);">Disclaimer:</strong> This valuation is an estimate based on current market multiples and the information provided. It is not a formal business appraisal, audit, or offer to purchase. Actual business value may vary based on market conditions, buyer demand, normalized financials, tangible and intangible assets, customer concentration, contracts, and other factors. A formal valuation and due diligence are required before any transaction.</p>
    </div>

  </div>

  <script is:inline>
    const MULTIPLES = {
      'Technology / Software':       { sdeL: 3.0, sdeH: 6.0, revM: 1.5 },
      'Professional Services':       { sdeL: 2.0, sdeH: 4.0, revM: 0.8 },
      'Healthcare / Medical':        { sdeL: 3.0, sdeH: 5.0, revM: 1.2 },
      'Retail':                      { sdeL: 1.5, sdeH: 3.0, revM: 0.4 },
      'Restaurant / Food & Beverage':{ sdeL: 1.5, sdeH: 3.0, revM: 0.4 },
      'Manufacturing':               { sdeL: 2.5, sdeH: 4.5, revM: 0.7 },
      'E-commerce':                  { sdeL: 2.0, sdeH: 4.0, revM: 0.8 },
      'Construction / Trades':       { sdeL: 2.0, sdeH: 3.5, revM: 0.5 },
      'Transportation / Logistics':  { sdeL: 2.0, sdeH: 3.5, revM: 0.5 },
      'Real Estate Services':        { sdeL: 2.5, sdeH: 4.0, revM: 0.9 },
      'Wholesale / Distribution':    { sdeL: 2.0, sdeH: 3.5, revM: 0.4 },
      'Financial Services':          { sdeL: 2.5, sdeH: 5.0, revM: 1.0 },
      'Marketing / Advertising':     { sdeL: 2.0, sdeH: 4.0, revM: 0.8 },
      'Other':                       { sdeL: 2.0, sdeH: 3.5, revM: 0.6 },
    };

    const YEARS_FACTOR = {
      under1: 0.70,
      '1to3': 0.85,
      '3to5': 1.00,
      '5to10': 1.10,
      over10: 1.20,
    };

    const YEARS_LABEL = {
      under1: 'Under 1 year',
      '1to3': '1 – 3 years',
      '3to5': '3 – 5 years',
      '5to10': '5 – 10 years',
      over10: '10+ years',
    };

    function fmt(n) {
      if (n >= 1e6) return '$' + (n / 1e6).toFixed(2).replace(/\.?0+$/, '') + 'M';
      if (n >= 1e3) return '$' + (n / 1e3).toFixed(0) + 'K';
      return '$' + n.toLocaleString();
    }

    function fmtFull(n) {
      return '$' + Math.round(n).toLocaleString();
    }

    function getInitials(name) {
      return name.split(/\s+/).slice(0, 2).map(w => w[0]).join('').toUpperCase();
    }

    function loadReport() {
      const raw = localStorage.getItem('valuationData');
      if (!raw) {
        window.location.href = '/valuation';
        return;
      }
      const d = JSON.parse(raw);

      document.getElementById('rBusinessName').textContent = d.businessName || 'Your Business';
      document.getElementById('rIndustry').textContent = d.industry + ' · ' + (YEARS_LABEL[d.yearsInBusiness] || '');
      document.getElementById('rGross').textContent = fmtFull(d.grossRevenue);
      document.getElementById('rNet').textContent = fmtFull(d.netIncome);
      document.getElementById('rYears').textContent = YEARS_LABEL[d.yearsInBusiness] || '—';
      document.getElementById('rDate').textContent = new Date(d.submittedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

      if (d.websiteUrl) {
        try {
          const domain = new URL(d.websiteUrl.startsWith('http') ? d.websiteUrl : 'https://' + d.websiteUrl).hostname.replace(/^www\./, '');
          const logoEl = document.getElementById('rBizLogo');
          const initEl = document.getElementById('rBizInitials');
          logoEl.src = 'https://logo.clearbit.com/' + domain;
          logoEl.onload = () => { logoEl.classList.add('visible'); initEl.style.display = 'none'; };
          logoEl.onerror = () => { initEl.textContent = getInitials(d.businessName); };
          initEl.textContent = getInitials(d.businessName);
        } catch { document.getElementById('rBizInitials').textContent = getInitials(d.businessName); }
      } else {
        document.getElementById('rBizInitials').textContent = getInitials(d.businessName);
      }

      const mult = MULTIPLES[d.industry] || MULTIPLES['Other'];
      const yFactor = YEARS_FACTOR[d.yearsInBusiness] || 1.0;
      const sde = d.netIncome;
      const gross = d.grossRevenue;

      const sdeLow  = Math.round(sde * mult.sdeL * yFactor);
      const sdeHigh = Math.round(sde * mult.sdeH * yFactor);
      const revEst  = Math.round(gross * mult.revM);

      let low, high;
      if (sde > 0) {
        low  = sdeLow;
        high = sdeHigh;
      } else {
        low  = Math.round(revEst * 0.8);
        high = Math.round(revEst * 1.2);
      }

      document.getElementById('rValuationRange').textContent = fmt(low) + ' – ' + fmt(high);
      document.getElementById('rValuationNote').textContent = 'Based on ' + d.industry + ' multiples · ' + YEARS_LABEL[d.yearsInBusiness];

      setTimeout(() => {
        document.getElementById('rConfidenceFill').style.width = '62%';
      }, 300);

      const tbody = document.getElementById('rMethodBody');
      const rows = [];

      if (sde > 0) {
        rows.push({
          method: 'SDE Multiple (Primary)',
          base: fmtFull(sde),
          mult: mult.sdeL.toFixed(1) + 'x – ' + mult.sdeH.toFixed(1) + 'x (adj. ' + yFactor.toFixed(2) + 'x years)',
          result: fmt(sdeLow) + ' – ' + fmt(sdeHigh),
          highlight: true,
        });
      }
      if (gross > 0) {
        rows.push({
          method: 'Revenue Multiple (Secondary)',
          base: fmtFull(gross),
          mult: mult.revM.toFixed(1) + 'x',
          result: fmt(revEst),
          highlight: false,
        });
      }

      tbody.innerHTML = rows.map(r =>
        '<tr class="' + (r.highlight ? 'highlight-row' : '') + '">' +
          '<td>' + r.method + '</td>' +
          '<td>' + r.base + '</td>' +
          '<td>' + r.mult + '</td>' +
          '<td>' + r.result + '</td>' +
        '</tr>'
      ).join('');

      if (d.ownerName) {
        const firstName = d.ownerName.split(' ')[0];
        document.getElementById('rPersonalNote').textContent =
          firstName + ', thank you for taking the first step. This estimate gives you a realistic starting point — but the true value of your business is often uncovered through a deeper conversation about your story, your goals, and the unique strengths you\'ve built over the years. I\'ll be reaching out shortly via ' + (d.contactMethod ? d.contactMethod.toLowerCase() : 'your preferred method') + ' to discuss next steps. In the meantime, feel free to reach out directly — I\'m here to help.';
      }
    }

    loadReport();

    // Fire Meta Pixel CompleteRegistration when the user reaches the report
    // page. This is a stronger signal than Lead alone — it confirms they
    // completed the form AND received their valuation. Use a higher value so
    // Meta's algorithm prefers users who reach this stage. Browser-only is
    // sufficient: the CAPI Lead from /api/submit already covered iOS users.
    try {
      const raw = localStorage.getItem('valuationData');
      if (raw && typeof fbq === 'function') {
        const d = JSON.parse(raw);
        // Generate a fresh eventId for CompleteRegistration so it's distinct
        // from the Lead event in Meta's deduplication logic.
        const regId = (window.crypto && window.crypto.randomUUID)
          ? window.crypto.randomUUID()
          : 'reg-' + Date.now() + '-' + Math.random().toString(36).slice(2, 10);
        fbq('track', 'CompleteRegistration', {
          content_name: 'Valuation Report Viewed',
          content_category: d.industry || 'unspecified',
          value: 250,
          currency: 'USD',
          status: 'completed',
        }, { eventID: regId });
      }
    } catch (_) { /* non-fatal */ }
  </script>
</BaseLayout>

<style is:global>
  body { background: var(--bg); }

  .report-wrap {
    max-width: 820px;
    margin: 0 auto;
    padding: 140px 24px 80px;
  }
  @media (max-width: 768px) {
    .report-wrap { padding-top: 120px; }
  }

  .report-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
  }

  .report-header {
    background: linear-gradient(135deg, #161b22 0%, #0d1117 100%);
    border-bottom: 1px solid var(--border);
    padding: 44px 48px;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }
  .report-header-left { flex: 1; min-width: 200px; }
  .report-hedgstone-logo { height: 32px; margin-bottom: 20px; }
  .report-title {
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 6px;
  }
  .report-business-name {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    color: var(--text);
    margin-bottom: 4px;
  }
  .report-industry {
    font-size: 0.9rem;
    color: var(--muted);
  }
  .report-biz-logo {
    width: 80px;
    height: 80px;
    border-radius: 12px;
    object-fit: contain;
    background: white;
    padding: 8px;
    border: 1px solid var(--border);
    display: none;
  }
  .report-biz-logo.visible { display: block; }
  .report-biz-initials {
    width: 80px;
    height: 80px;
    border-radius: 12px;
    background: rgba(212,168,67,0.1);
    border: 1px solid rgba(212,168,67,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    color: var(--gold);
    font-weight: 700;
    flex-shrink: 0;
  }

  .valuation-hero {
    padding: 48px 48px 40px;
    text-align: center;
    border-bottom: 1px solid var(--border);
    background: linear-gradient(180deg, rgba(212,168,67,0.04) 0%, transparent 100%);
  }
  .valuation-label {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 12px;
  }
  .valuation-range {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.4rem, 6vw, 4rem);
    color: var(--gold);
    font-weight: 700;
    margin-bottom: 8px;
    line-height: 1;
  }
  .valuation-note {
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 24px;
  }
  .confidence-bar-wrap {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }
  .confidence-label {
    font-size: 0.75rem;
    color: var(--muted);
    text-align: left;
    display: flex;
    justify-content: space-between;
    width: 300px;
  }
  .confidence-bar {
    width: 300px;
    height: 8px;
    background: var(--border);
    border-radius: 100px;
    overflow: hidden;
  }
  .confidence-fill {
    height: 100%;
    background: linear-gradient(90deg, #a87c1f, var(--green), #e8c46a);
    border-radius: 100px;
    transition: width 1.2s ease;
  }

  .breakdown-section {
    padding: 40px 48px;
    border-bottom: 1px solid var(--border);
  }
  .breakdown-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 24px;
    font-family: 'Inter', sans-serif;
  }
  .breakdown-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 16px;
  }
  .breakdown-item {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px;
  }
  .breakdown-item .b-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 6px;
  }
  .breakdown-item .b-value {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    color: var(--text);
  }
  .breakdown-item .b-sub {
    font-size: 0.78rem;
    color: var(--muted);
    margin-top: 3px;
  }

  .method-section {
    padding: 36px 48px;
    border-bottom: 1px solid var(--border);
  }
  .method-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 12px;
    font-family: 'Inter', sans-serif;
  }
  .method-text {
    font-size: 0.88rem;
    color: var(--muted);
    line-height: 1.7;
  }
  .method-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 16px;
  }
  .method-table th {
    text-align: left;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 8px 12px;
    border-bottom: 1px solid var(--border);
  }
  .method-table td {
    font-size: 0.88rem;
    color: var(--text);
    padding: 10px 12px;
    border-bottom: 1px solid rgba(48,54,61,0.5);
  }
  .method-table tr:last-child td { border-bottom: none; }
  .highlight-row td { color: var(--gold); font-weight: 600; }

  .broker-section {
    padding: 44px 48px;
    display: flex;
    gap: 36px;
    align-items: flex-start;
    background: linear-gradient(135deg, rgba(212,168,67,0.04) 0%, transparent 100%);
  }
  .broker-photo {
    width: 120px;
    height: 140px;
    border-radius: 12px;
    object-fit: cover;
    object-position: top;
    flex-shrink: 0;
    border: 2px solid rgba(212,168,67,0.3);
  }
  .broker-info { flex: 1; }
  .broker-info .greeting {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 8px;
  }
  .broker-info h3 {
    font-size: 1.5rem;
    color: var(--text);
    margin-bottom: 2px;
  }
  .broker-info .broker-title {
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 16px;
  }
  .broker-info p {
    font-size: 0.92rem;
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 20px;
  }
  .broker-contact-row {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .broker-contact-row a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.88rem;
    color: var(--muted);
    transition: color 0.2s;
  }
  .broker-contact-row a:hover { color: var(--gold); }

  .report-footer {
    padding: 24px 48px;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .report-footer p {
    font-size: 0.75rem;
    color: var(--muted);
  }
  .report-footer .actions {
    display: flex;
    gap: 10px;
  }
  .btn-print {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--muted);
    padding: 8px 18px;
    border-radius: 6px;
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .btn-print:hover {
    border-color: var(--gold);
    color: var(--text);
  }

  .disclaimer-box {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px 24px;
    margin-top: 24px;
  }
  .disclaimer-box p {
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.65;
  }

  @media (max-width: 680px) {
    .report-header, .valuation-hero, .breakdown-section,
    .method-section, .broker-section, .report-footer { padding: 28px 24px; }
    .breakdown-grid { grid-template-columns: 1fr 1fr; }
    .broker-section { flex-direction: column; align-items: center; text-align: center; }
    .broker-contact-row { justify-content: center; }
    .confidence-label, .confidence-bar { width: 240px; }
  }

  /* ─── PRINT / "Save as PDF" — single-page light-themed report ──────────
     Goal: when the user clicks Save / Print, they get a clean one-page
     US Letter PDF that reads like a professional valuation document
     instead of the dark screen UI broken across 2-3 pages.
     We override colors to a print-friendly light palette, force the
     browser to render backgrounds (so the gold accents show), and
     tighten every section's spacing so the whole report fits on one
     page at ~0.4 inch margins. */

  @page {
    size: letter;
    margin: 0.45in 0.5in;
  }

  @media print {
    /* Force backgrounds + colors to render in print (Chrome/Safari/Edge). */
    *, *::before, *::after {
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
    }

    /* Light theme overrides — applied only at print time. */
    :root {
      --bg: #ffffff;
      --surface: #ffffff;
      --card: #f7f5ee;
