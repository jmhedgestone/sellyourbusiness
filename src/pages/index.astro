---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const title =
  'Sell Your Business | John Matsis – Business & Investment Property Broker';
const description =
  'Find out what your business is worth. Get a free, confidential business valuation from John Matsis, Business & Investment Property Broker and Principal with HedgeStone Business Advisors.';

// Page-specific schema. LLMs use Service + FAQPage to summarize what you offer
// and to surface answer-blocks for specific queries.
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    serviceType: 'Business Brokerage',
    name: 'Confidential Business Sale & Valuation',
    provider: {
      '@type': 'Organization',
      name: 'HedgeStone Business Advisors',
      url: 'https://www.hedgestone.com',
    },
    areaServed: 'United States',
    description:
      'Confidential business brokerage, free business valuation, and end-to-end sale process for business owners exiting their company.',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
      name: 'Free Business Valuation',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'How is a small business valued when selling?',
        acceptedAnswer: {
          '@type': 'Answer',
          text:
            "Most small businesses are valued using a multiple of Seller's Discretionary Earnings (SDE) — the profit available to a working owner — with the multiple typically ranging from 1.5x to 6x depending on industry, years in operation, customer concentration, and transferability of the business.",
        },
      },
      {
        '@type': 'Question',
        name: 'How do I sell my business confidentially?',
        acceptedAnswer: {
          '@type': 'Answer',
          text:
            'A confidential sale starts with a blind teaser that identifies industry, size, and geography without revealing the company. Interested buyers sign an NDA before receiving a Confidential Information Memorandum (CIM). Staff, customers, landlords, and competitors are not notified until after a Letter of Intent is signed and deal terms are agreed.',
        },
      },
      {
        '@type': 'Question',
        name: 'How long does it take to sell a business?',
        acceptedAnswer: {
          '@type': 'Answer',
          text:
            'Most small- and mid-market businesses take 6–12 months from listing to closing. Preparation (financial cleanup, CIM, valuation) adds 1–3 months before going to market. Businesses with clean books, recurring revenue, and low owner dependence close faster.',
        },
      },
      {
        '@type': 'Question',
        name: 'What documents do I need to sell my business?',
        acceptedAnswer: {
          '@type': 'Answer',
          text:
            "You'll need 3 years of profit & loss statements and tax returns, current balance sheet, list of assets (FF&E), lease and material contracts, employee census, and a summary of add-backs. A formal CIM is prepared by your broker from these inputs.",
        },
      },
    ],
  },
];
---

<BaseLayout title={title} description={description} schema={schema}>
  <Nav variant="home" />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-badge anim" style="transition-delay:100ms">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Free &amp; Confidential
      </div>
      <h1 class="anim" style="transition-delay:220ms">What Is Your<br /><em>Business Worth?</em></h1>
      <p class="anim" style="transition-delay:340ms">Get an industry-standard valuation estimate in under 3 minutes — no obligation, no cost, and completely confidential.</p>
      <div class="hero-actions anim" style="transition-delay:460ms">
        <a href="/funnel" class="btn btn-primary btn-lg btn-pulse">
          Start Free Valuation
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>
      </div>
      <div class="hero-trust anim" style="transition-delay:580ms">
        <div class="trust-item">
          <span class="num" data-count="100%">100%</span>
          <span class="label">Confidential</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <span class="num">$0</span>
          <span class="label">Cost to You</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <span class="num">3 Min</span>
          <span class="label">To Complete</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <span class="num">No</span>
          <span class="label">Obligation</span>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section>
    <div class="container">
      <div class="section-label anim">The Process</div>
      <h2 class="section-title anim" style="transition-delay:100ms">Simple. Fast. Confidential.</h2>
      <p class="section-subtitle anim" style="transition-delay:200ms">In three easy steps, you'll have a clear picture of what your business could sell for — and a seasoned broker in your corner.</p>
      <div class="steps-grid anim-stagger">
        <div class="step-card">
          <div class="step-num">01</div>
          <h3>Share Your Details</h3>
          <p>Answer a few quick questions about your business — takes less than 3 minutes. No sensitive documents required.</p>
        </div>
        <div class="step-card">
          <div class="step-num">02</div>
          <h3>Get Your Valuation</h3>
          <p>We apply industry-standard multiples to generate a realistic estimated value range based on your financials and sector.</p>
        </div>
        <div class="step-card">
          <div class="step-num">03</div>
          <h3>Connect With John</h3>
          <p>Receive your branded valuation report and a personal follow-up to discuss your goals, timeline, and next steps.</p>
        </div>
        <div class="step-card">
          <div class="step-num">04</div>
          <h3>Go to Market</h3>
          <p>If you choose to move forward, leverage our buyer network of private individuals, family offices, and PE firms.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BROKER BIO -->
  <section class="bio-section">
    <div class="container">
      <div class="bio-inner">
        <div class="bio-image-wrap anim anim-left">
          <img src="/assets/john-matsis.jpg" alt="John Matsis – Business & Investment Property Broker" />
        </div>
        <div class="bio-content anim anim-right" style="transition-delay:150ms">
          <div class="section-label">Your Broker</div>
          <h2 class="name">John Matsis</h2>
          <div class="title-tag">Business &amp; Investment Property Broker and Principal</div>
          <p>I bring hands-on experience building, acquiring, exiting, and investing in businesses and real estate of all types. I'm deeply involved at every stage of the process — from the first conversation to the final closing — because what is often a complex transaction deserves a steady, knowledgeable hand guiding it toward the best possible outcome.</p>
          <p>Confidentiality, deep knowledge across a wide span of industries and investment assets, and the ability to harness technology to streamline and scale are the primary hallmarks of my work. When you're ready to explore what your business could be worth — and what comes next — I'm here to help you navigate it with clarity and confidence.</p>
          <div class="bio-contact">
            <a href="tel:2126780100">
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              (212) 678-0100
            </a>
            <a href="mailto:john.matsis@hedgestone.com">
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              john.matsis@hedgestone.com
            </a>
            <a href="https://www.instagram.com/johnmatsis" target="_blank" rel="noopener">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              @johnmatsis
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- HEDGSTONE -->
  <section>
    <div class="container">
      <div class="hedg-inner">
        <div class="hedg-content anim anim-left">
          <div class="section-label">Backed By</div>
          <h2 class="section-title">HedgeStone Business Advisors</h2>
          <p>I operate as part of HedgeStone Business Advisors — one of the most powerful business brokerage networks in the country. With a team of over 300 agents nationwide, we combine local expertise with a national reach that gives your business maximum exposure to qualified buyers.</p>
          <p>Our buyer pool includes private individuals, family offices, private equity firms, and successful operators who are always seeking their next acquisition. With 10 million social media views per month and a platform built to match sellers with the right buyers, HedgeStone delivers results.</p>
          <div class="hedg-stats anim-stagger">
            <div class="hedg-stat">
              <div class="value" data-count="300+">300+</div>
              <div class="desc">Agents across the US</div>
            </div>
            <div class="hedg-stat">
              <div class="value" data-count="10M">10M</div>
              <div class="desc">Social views per month</div>
            </div>
            <div class="hedg-stat">
              <div class="value">PE &amp; FO</div>
              <div class="desc">Institutional buyer access</div>
            </div>
            <div class="hedg-stat">
              <div class="value" data-count="100%">100%</div>
              <div class="desc">Confidential process</div>
            </div>
          </div>
        </div>
        <div class="hedg-logo-box anim anim-right" style="transition-delay:150ms">
          <img src="https://www.hedgestone.com/wp-content/uploads/2022/07/HedgeStone-logo-sh.svg" alt="HedgeStone Business Advisors" />
          <p>A national network of business brokers and advisors committed to helping owners exit on their terms — with maximum value and full confidentiality.</p>
          <a href="/funnel" class="btn btn-outline">Get My Free Valuation</a>
        </div>
      </div>
    </div>
  </section>

  <!-- KNOWLEDGE BASE / PILLAR LINKS -->
  <section class="resources-section">
    <div class="container">
      <div class="section-label anim">Knowledge Base</div>
      <h2 class="section-title anim" style="transition-delay:100ms">Selling a Business, Explained.</h2>
      <p class="section-subtitle anim" style="transition-delay:200ms">Practical, broker-written guides on selling and on how businesses are actually valued.</p>

      <div class="resources-pillars anim-stagger">
        <a href="/how-to-sell-a-business" class="resource-card resource-card-hub">
          <div class="resource-eyebrow">Complete Guide</div>
          <h3>How to Sell a Business</h3>
          <p>The end-to-end playbook: timing, preparation, valuation, marketing, LOI, due diligence, and closing.</p>
          <span class="resource-link">Read the guide →</span>
        </a>
        <a href="/business-valuation" class="resource-card resource-card-hub">
          <div class="resource-eyebrow">Practical Guide</div>
          <h3>Business Valuation</h3>
          <p>How small- and mid-market businesses are actually valued — SDE, EBITDA, multiples, add-backs, and the levers that move your number.</p>
          <span class="resource-link">Read the guide →</span>
        </a>
      </div>

      <div class="resources-grid anim-stagger">
        <a href="/how-to-sell-a-business/when-to-sell-a-business" class="resource-card">
          <div class="resource-eyebrow">Timing</div>
          <h3>When to Sell</h3>
          <p>The three-factor framework for picking the right exit window.</p>
        </a>
        <a href="/how-to-sell-a-business/how-to-prepare-your-business-for-sale" class="resource-card">
          <div class="resource-eyebrow">Preparation</div>
          <h3>12-Month Pre-Sale Checklist</h3>
          <p>Financial, operational, and legal cleanup that raises your multiple.</p>
        </a>
        <a href="/business-valuation/what-is-sde-sellers-discretionary-earnings" class="resource-card">
          <div class="resource-eyebrow">Valuation</div>
          <h3>What Is SDE?</h3>
          <p>The earnings metric used to value most small businesses — and why your tax-return net income is the wrong number.</p>
        </a>
        <a href="/business-valuation/business-valuation-multiples-by-industry" class="resource-card">
          <div class="resource-eyebrow">Benchmarks</div>
          <h3>Multiples by Industry (2026)</h3>
          <p>What multiples businesses actually sell for — service, manufacturing, healthcare, online, and more.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section class="cta-banner">
    <div class="section-label anim">Ready?</div>
    <h2 class="section-title anim" style="transition-delay:100ms">Find Out What Your Business Is Worth</h2>
    <p class="anim" style="transition-delay:200ms">It takes less than 3 minutes. No commitment, no cost — just clarity.</p>
    <a href="/funnel" class="btn btn-primary btn-lg anim btn-pulse" style="transition-delay:300ms">
      Start My Free Valuation
      <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
    </a>
  </section>

  <Footer variant="full" />

  <script src="/assets/animations.js" is:inline></script>
  <script is:inline>
    document.querySelectorAll('.hero .anim').forEach(el => {
      setTimeout(() => el.classList.add('is-visible'), 50);
    });
  </script>
</BaseLayout>

<style is:global>
  /* HERO */
  .hero {
    padding: 160px 0 120px;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(45,184,127,0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-inner {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    padding: 0 24px;
    position: relative;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--green-dim);
    border: 1px solid rgba(45,184,127,0.3);
    color: var(--green);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 8px 18px;
    border-radius: 100px;
    margin-bottom: 32px;
  }
  .hero h1 {
    font-size: clamp(2.6rem, 6vw, 4.2rem);
    color: var(--text);
    margin-bottom: 24px;
    letter-spacing: -0.02em;
  }
  .hero h1 em {
    font-style: normal;
    color: var(--gold);
  }
  .hero p {
    font-size: 1.2rem;
    color: var(--muted);
    margin-bottom: 48px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.75;
  }
  .hero-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .hero-trust {
    margin-top: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 32px;
    flex-wrap: wrap;
  }
  .trust-item {
    text-align: center;
  }
  .trust-item .num {
    display: block;
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--green);
  }
  .trust-item .label {
    font-size: 0.8rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .trust-divider {
    width: 1px;
    height: 40px;
    background: var(--border);
  }

  /* HOW IT WORKS */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 24px;
    margin-top: 56px;
  }
  .step-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 32px 28px;
    position: relative;
  }
  .step-num {
    font-family: 'Playfair Display', serif;
    font-size: 3rem;
    font-weight: 700;
    color: var(--green);
    opacity: 0.85;
    line-height: 1;
    margin-bottom: 16px;
  }
  .step-card h3 {
    font-size: 1.1rem;
    color: var(--text);
    margin-bottom: 10px;
  }
  .step-card p {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.65;
  }

  /* BROKER BIO */
  .bio-section {
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .bio-inner {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: 72px;
    align-items: center;
  }
  .bio-image-wrap {
    position: relative;
  }
  .bio-image-wrap::before {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: 16px;
    background: linear-gradient(135deg, var(--gold), transparent 60%);
    z-index: 0;
  }
  .bio-image-wrap img {
    width: 100%;
    border-radius: 14px;
    display: block;
    position: relative;
    z-index: 1;
    object-fit: cover;
    aspect-ratio: 3/4;
  }
  .bio-content .name {
    font-size: 2.4rem;
    color: var(--text);
    margin-bottom: 4px;
  }
  .bio-content .title-tag {
    font-size: 0.9rem;
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    color: var(--gold);
    margin-bottom: 28px;
    letter-spacing: 0.03em;
  }
  .bio-content p {
    font-size: 1.05rem;
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 18px;
  }
  .bio-contact {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 28px;
  }
  .bio-contact a {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--muted);
    font-size: 0.95rem;
    transition: color 0.2s;
  }
  .bio-contact a:hover { color: var(--gold); }
  .bio-contact svg { flex-shrink: 0; }

  /* HEDGSTONE */
  .hedg-inner {
    display: grid;
    grid-template-columns: 1fr 440px;
    gap: 72px;
    align-items: center;
  }
  .hedg-content p {
    font-size: 1.05rem;
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 18px;
  }
  .hedg-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 40px;
  }
  .hedg-stat {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px 22px;
  }
  .hedg-stat .value {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    color: var(--gold);
    font-weight: 700;
  }
  .hedg-stat .desc {
    font-size: 0.85rem;
    color: var(--muted);
    margin-top: 4px;
  }
  .hedg-logo-box {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 48px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }
  .hedg-logo-box img {
    width: 100%;
    max-width: 260px;
  }
  .hedg-logo-box p {
    text-align: center;
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.65;
  }

  /* RESOURCES / KNOWLEDGE BASE */
  .resources-section {
    padding: 100px 0;
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .resources-pillars {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 18px;
    margin-top: 48px;
  }
  .resources-pillars .resource-card-hub {
    background: linear-gradient(135deg, rgba(45,184,127,0.08) 0%, rgba(45,184,127,0.02) 100%);
    border-color: rgba(45,184,127,0.3);
    padding: 32px;
  }
  .resources-pillars .resource-card-hub h3 {
    font-size: 1.6rem;
  }
  .resources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 18px;
    margin-top: 18px;
  }
  .resource-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 26px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
  }
  .resource-card:hover {
    transform: translateY(-3px);
    border-color: rgba(45,184,127,0.5);
    box-shadow: 0 14px 36px rgba(0,0,0,0.28);
  }
  .resource-card .resource-eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 10px;
  }
  .resource-card h3 {
    font-family: 'Inter', sans-serif;
    font-size: 1.15rem;
    color: var(--text);
    margin-bottom: 10px;
    line-height: 1.3;
    font-weight: 700;
  }
  .resource-card-hub h3 {
    font-size: 1.5rem;
  }
  .resource-card p {
    font-size: 0.92rem;
    color: var(--muted);
    line-height: 1.65;
    margin-bottom: 14px;
    flex: 1;
  }
  .resource-card .resource-link {
    font-size: 0.88rem;
    color: var(--gold);
    font-weight: 600;
  }

  /* CTA BANNER */
  .cta-banner {
    text-align: center;
    padding: 100px 24px;
    position: relative;
    overflow: hidden;
  }
  .cta-banner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 100% at 50% 100%, rgba(45,184,127,0.07) 0%, transparent 70%);
    pointer-events: none;
  }
  .cta-banner h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 20px;
  }
  .cta-banner p {
    font-size: 1.1rem;
    color: var(--muted);
    margin-bottom: 40px;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 900px) {
    .bio-inner, .hedg-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .bio-image-wrap { max-width: 320px; margin: 0 auto; }
  }
  @media (max-width: 600px) {
    .trust-divider { display: none; }
