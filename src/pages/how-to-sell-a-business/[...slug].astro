---
import { getCollection, getEntry } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const all = await getCollection('articles', (a) => !a.data.draft && a.data.pillar === 'how-to-sell');
  return all.map((a) => ({
    params: { slug: a.slug },
    props: { entry: a },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Resolve relatedArticles (slugs) → full hrefs. Cross-pillar related links
// route to the referenced article's pillar prefix.
const PILLAR_PREFIX = {
  'how-to-sell': '/how-to-sell-a-business',
  'valuation': '/business-valuation',
  'confidential-sale': '/confidential-sale',
  'tech-valuation': '/technology-valuation',
};

const related = [];
if (entry.data.relatedArticles) {
  for (const slug of entry.data.relatedArticles) {
    const rel = await getEntry('articles', slug);
    if (rel) {
      const prefix = PILLAR_PREFIX[rel.data.pillar] || '/how-to-sell-a-business';
      related.push({
        title: rel.data.title,
        description: rel.data.description,
        href: `${prefix}/${rel.slug}`,
      });
    }
  }
}
---

<ArticleLayout
  title={entry.data.title}
  description={entry.data.description}
  answer={entry.data.answer}
  publishDate={entry.data.publishDate}
  updatedDate={entry.data.updatedDate}
  author={entry.data.author}
  pillar="how-to-sell"
  pillarTitle="How to Sell a Business"
  pillarHref="/how-to-sell-a-business"
  slug={entry.slug}
  faqs={entry.data.faqs}
  relatedArticles={related}
  ogImage={entry.data.ogImage}
>
  <Content />
</ArticleLayout>
