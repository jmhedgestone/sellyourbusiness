---
import SEO from '../components/SEO.astro';
import MetaPixel from '../components/MetaPixel.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article' | 'profile';
  noindex?: boolean;
  schema?: Record<string, unknown>[];
  publishedTime?: string;
  modifiedTime?: string;
  bodyClass?: string;
}

const {
  title,
  description,
  canonical,
  ogImage,
  ogType,
  noindex,
  schema,
  publishedTime,
  modifiedTime,
  bodyClass,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" href="/assets/favicon.png" />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-N3ZZXGVB5R"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-N3ZZXGVB5R');
    </script>

    <!-- Meta Pixel -->
    <MetaPixel />

    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
      schema={schema}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
    />

    <slot name="head" />
  </head>
  <body class={bodyClass}>
    <slot />
  </body>
</html>
