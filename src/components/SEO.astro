---
// SEO + AEO component.
// - Emits standard meta (title, description, canonical, OG, Twitter)
// - Emits schema.org JSON-LD: always includes Organization + Person (John Matsis) + WebSite.
// - Accepts optional `schema` prop — any additional schema.org objects (Article, FAQPage, HowTo, BreadcrumbList, etc.)
//   that describe the specific page. These are what LLMs parse to understand and cite the content.

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article' | 'profile';
  noindex?: boolean;
  schema?: Record<string, unknown>[];
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  title,
  description,
  canonical,
  ogImage = '/assets/john-matsis.jpg',
  ogType = 'website',
  noindex = false,
  schema = [],
  publishedTime,
  modifiedTime,
} = Astro.props;

const siteUrl = 'https://sellyourbusiness.com';
const canonicalURL = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteUrl).toString();

// Always-on baseline schema — describes the operating entity, the broker, and the site.
// LLMs heavily weight `sameAs` on Person/Organization for authority/identity resolution.
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'HedgeStone Business Advisors',
  alternateName: 'SellYourBusiness.com',
  url: siteUrl,
  logo: 'https://www.hedgestone.com/wp-content/uploads/2022/07/HedgeStone-logo-sh.svg',
  description:
    'Business brokerage and advisory firm helping owners confidentially sell their business for maximum value.',
  areaServed: 'United States',
  serviceType: ['Business Brokerage', 'Business Valuation', 'Mergers and Acquisitions Advisory'],
  telephone: '+1-212-678-0100',
  email: 'john.matsis@hedgestone.com',
  sameAs: ['https://www.hedgestone.com', 'https://www.instagram.com/johnmatsis'],
};

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'John Matsis',
  jobTitle: 'Business & Investment Property Broker and Principal',
  worksFor: {
    '@type': 'Organization',
    name: 'HedgeStone Business Advisors',
    url: 'https://www.hedgestone.com',
  },
  telephone: '+1-212-678-0100',
  email: 'john.matsis@hedgestone.com',
  image: new URL('/assets/john-matsis.jpg', siteUrl).toString(),
  url: siteUrl,
  sameAs: ['https://www.instagram.com/johnmatsis'],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  url: siteUrl,
  name: 'SellYourBusiness.com',
  description:
    'Free confidential business valuation and expert brokerage for owners ready to exit.',
  publisher: { '@type': 'Organization', name: 'HedgeStone Business Advisors' },
};

const allSchema = [organizationSchema, personSchema, websiteSchema, ...schema];
---

<!-- Primary meta -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
{noindex && <meta name="robots" content="noindex, nofollow" />}
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={ogImageAbsolute} />
<meta property="og:site_name" content="SellYourBusiness.com" />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageAbsolute} />

<!-- JSON-LD schema (baseline + page-specific) -->
{allSchema.map((obj) => (
  <script type="application/ld+json" set:html={JSON.stringify(obj)} />
))}
