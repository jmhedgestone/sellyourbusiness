---
// Meta (Facebook) Pixel base code.
// Fires PageView on every page load. The Pixel ID is read from PUBLIC_META_PIXEL_ID
// at build time; if unset, the component renders nothing so dev/test environments
// don't spam the production pixel.
const pixelId = import.meta.env.PUBLIC_META_PIXEL_ID?.trim();
---

{pixelId && (
  <>
    <script is:inline define:vars={{ pixelId }}>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', pixelId);
      fbq('track', 'PageView');

      // UTM + click-id persistence. First-touch values are stored on the
      // first visit that carries them and never overwritten — that's the
      // ad we'll attribute the eventual Lead to. Last-touch values are
      // refreshed on every paid landing so we can also see the most
      // recent campaign in case a user revisits via a different ad.
      try {
        var trackedKeys = ['utm_source','utm_medium','utm_campaign','utm_term','utm_content','fbclid','gclid'];
        var qp = new URLSearchParams(window.location.search);
        var inbound = {};
        var hasAny = false;
        for (var i = 0; i < trackedKeys.length; i++) {
          var v = qp.get(trackedKeys[i]);
          if (v) { inbound[trackedKeys[i]] = v; hasAny = true; }
        }
        if (hasAny) {
          inbound._t = Date.now();
          inbound._lp = window.location.pathname;
          var firstRaw = localStorage.getItem('syb_utm_first');
          if (!firstRaw) localStorage.setItem('syb_utm_first', JSON.stringify(inbound));
          localStorage.setItem('syb_utm_last', JSON.stringify(inbound));
        }
      } catch (_) { /* localStorage may be disabled — non-fatal */ }

      // Site-wide click delegate: fire Meta Contact event whenever a
      // tel: or mailto: link is clicked, anywhere on the page. Captures
      // homepage bio links, footer, article author bios, and the report
      // page broker contact row without per-page wiring.
      document.addEventListener('click', function (e) {
        var a = e.target && e.target.closest && e.target.closest('a[href]');
        if (!a) return;
        var href = a.getAttribute('href') || '';
        var channel = null;
        if (href.indexOf('tel:') === 0) channel = 'phone';
        else if (href.indexOf('mailto:') === 0) channel = 'email';
        if (!channel || typeof fbq !== 'function') return;
        try {
          fbq('track', 'Contact', {
            content_name: channel === 'phone' ? 'Phone Click' : 'Email Click',
            content_category: channel,
            source_path: window.location.pathname,
          });
        } catch (_) { /* never block the navigation */ }
      }, { capture: true });
    </script>
    <noscript>
      <img
        height="1"
        width="1"
        style="display:none"
        src={`https://www.facebook.com/tr?id=${pixelId}&ev=PageView&noscript=1`}
        alt=""
      />
    </noscript>
  </>
)}
