---
export interface Props {
  variant?: 'full' | 'minimal';
}
const { variant = 'full' } = Astro.props;
const year = new Date().getFullYear();
---

{variant === 'full' ? (
  <footer>
    <div class="footer-inner">
      <div class="footer-top">
        <div class="footer-brand">
          <img
            src="https://www.hedgestone.com/wp-content/uploads/2022/07/HedgeStone-logo-sh.svg"
            alt="HedgeStone Business Advisors"
          />
          <p>
            John Matsis &mdash; Business &amp; Investment Property Broker and Principal. Based in
            New York City &mdash; the business capital of the world. Backed by HedgeStone Business
            Advisors.
          </p>
        </div>
        <div class="footer-links">
          <h4>Resources</h4>
          <ul>
            <li><a href="/how-to-sell-a-business">How to Sell a Business</a></li>
            <li><a href="/business-valuation">Business Valuation Guide</a></li>
            <li><a href="/confidential-sale">Confidential Sale Guide</a></li>
            <li><a href="/technology-valuation">Technology &amp; Valuation</a></li>
            <li><a href="/private-equity">Selling to Private Equity</a></li>
            <li><a href="/real-estate">Selling With Real Estate</a></li>
            <li><a href="/quality-of-earnings">Quality of Earnings</a></li>
            <li><a href="/seller-financing-calculator">Seller Financing Calculator</a></li>
            <li><a href="/valuation">Free Valuation</a></li>
          </ul>
        </div>
        <div class="footer-links">
          <h4>Contact</h4>
          <ul>
            <li><a href="tel:2126780100">(212) 678-0100</a></li>
            <li><a href="mailto:john.matsis@hedgestone.com">john.matsis@hedgestone.com</a></li>
            <li>
              <a href="https://www.instagram.com/johnmatsis" target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:7px;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                @johnmatsis
              </a>
            </li>
          </ul>
        </div>
        <div class="footer-links">
          <h4>Legal</h4>
          <ul>
            <li><a href="/privacy">Privacy Policy</a></li>
            <li><a href="/terms">Terms &amp; Conditions</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {year} John Matsis &mdash; HedgeStone Business Advisors. All rights reserved.</p>
        <p>
          <a href="/privacy">Privacy</a> &middot; <a href="/terms">Terms</a>
        </p>
      </div>
    </div>
  </footer>
) : (
  <footer>
    <div class="footer-inner">
      <div class="footer-bottom">
        <p>&copy; {year} John Matsis &mdash; HedgeStone Business Advisors. All rights reserved.</p>
        <p>
          <a href="/privacy">Privacy</a> &middot; <a href="/terms">Terms</a>
