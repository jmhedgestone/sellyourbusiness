---
export interface Props {
  variant?: 'full' | 'minimal';
}
const { variant = 'full' } = Astro.props;
const year = new Date().getFullYear();
---

{variant === 'full' ? (
  <footer>
    <div class="footer-inner">
      <div class="footer-top">
        <div class="footer-brand">
          <img
            src="https://www.hedgestone.com/wp-content/uploads/2022/07/HedgeStone-logo-sh.svg"
            alt="HedgeStone Business Advisors"
          />
          <p>
            John Matsis &mdash; Business &amp; Investment Property Broker and Principal. Backed by
            HedgeStone Business Advisors.
          </p>
          <p class="footer-location">
            <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true" style="vertical-align:-2px;margin-right:6px;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            Based in New York City &mdash; the business capital of the world.
          </p>
        </div>
        <div class="footer-links">
          <h4>Resources</h4>
          <ul>
            <li><a href="/how-to-sell-a-business">How to Sell a Business</a></li>
            <li><a href="/business-valuation">Business Valuation Guide</a></li>
            <li><a href="/funnel">Free Valuation</a></li>
          </ul>
        </div>
        <div class="footer-links">
          <h4>Contact</h4>
          <ul>
            <li><a href="tel:2126780100">(212) 678-0100</a></li>
            <li><a href="mailto:john.matsis@hedgestone.com">john.matsis@hedgestone.com</a></li>
          </ul>
        </div>
        <div class="footer-links">
          <h4>Legal</h4>
          <ul>
            <li><a href="/privacy">Privacy Policy</a></li>
            <li><a href="/terms">Terms &amp; Conditions</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {year} John Matsis &mdash; HedgeStone Business Advisors. All rights reserved.</p>
        <p>
          <a href="/privacy">Privacy</a> &middot; <a href="/terms">Terms</a>
        </p>
      </div>
    </div>
  </footer>
) : (
  <footer>
    <div class="footer-inner">
      <div class="footer-bottom">
        <p>&copy; {year} John Matsis &mdash; HedgeStone Business Advisors. All rights reserved.</p>
        <p>
          <a href="/privacy">Privacy</a> &middot; <a href="/terms">Terms</a>
        </p>
      </div>
    </div>
  </footer>
)}
