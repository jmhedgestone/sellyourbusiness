---
// Article scroll-depth tracker. Fires Meta's `trackCustom` ArticleScrollDepth
// event at 25/50/75/100% reading progress, once per threshold per page load.
//
// Use case: build content-engagement audiences in Ads Manager — for example,
// "users who read 75%+ of any article in the last 30 days" makes a strong
// retargeting pool because high read-depth correlates with intent. Custom
// data (depth_percent, content_path, content_title) lets you segment by
// individual article.
//
// Mount inside ArticleLayout and the pillar hub. Top of page (>0%) counts
// as a 25 only when the user actually scrolls — landing on a short page
// that fits in viewport without scroll won't fire.
const { contentTitle } = Astro.props;
---

<script is:inline define:vars={{ contentTitle }}>
  (function () {
    var thresholds = [25, 50, 75, 100];
    var fired = {};
    var ticking = false;

    function calc() {
      ticking = false;
      var doc = document.documentElement;
      var scrolled = window.scrollY || window.pageYOffset || 0;
      var viewport = window.innerHeight || doc.clientHeight;
      var total = doc.scrollHeight - viewport;
      if (total <= 0) return;
      var pct = Math.min(100, Math.max(0, (scrolled / total) * 100));
      for (var i = 0; i < thresholds.length; i++) {
        var t = thresholds[i];
        if (pct >= t && !fired[t]) {
          fired[t] = true;
          if (typeof fbq === 'function') {
            try {
              fbq('trackCustom', 'ArticleScrollDepth', {
                depth_percent: t,
                content_path: window.location.pathname,
                content_title: contentTitle || document.title,
              });
            } catch (_) { /* never block UI */ }
          }
        }
      }
    }

    function onScroll() {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(calc);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    // First calc after layout settles, in case the user lands deep-linked.
    setTimeout(calc, 250);
  })();
</script>
